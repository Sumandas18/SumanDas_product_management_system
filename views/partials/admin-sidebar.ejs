<!-- Admin Sidebar (Minimal dark matte design) -->
<aside class="w-64 bg-zinc-950 border-r border-zinc-800 flex-shrink-0 hidden md:flex flex-col rounded-l-2xl shadow-2xl">
  <div class="p-6 border-b border-zinc-900 flex justify-center">
    <h2 class="text-xl font-black tracking-widest text-zinc-300">ADMIN<span class="text-red-500">.</span></h2>
  </div>

  <nav class="flex-grow p-4 space-y-2">
    <!-- Dashboard Link -->
    <a href="/admin" class="flex items-center gap-3 px-4 py-3 rounded-md text-sm font-semibold transition-all <%= typeof activeMenu !== 'undefined' && activeMenu === 'dashboard' ? 'bg-red-600 text-white shadow-lg shadow-red-500/20' : 'text-zinc-400 hover:bg-zinc-900 hover:text-red-400' %>">
      <svg class="w-5 h-5 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
      Dashboard
    </a>

    <!-- Categories Link -->
    <a href="/admin/categories" class="flex items-center gap-3 px-4 py-3 rounded-md text-sm font-semibold transition-all <%= typeof activeMenu !== 'undefined' && activeMenu === 'categories' ? 'bg-red-600 text-white shadow-lg shadow-red-500/20' : 'text-zinc-400 hover:bg-zinc-900 hover:text-red-400' %>">
      <svg class="w-5 h-5 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
      Categories
    </a>

    <!-- Products Link -->
    <a href="/admin/products" class="flex items-center gap-3 px-4 py-3 rounded-md text-sm font-semibold transition-all <%= typeof activeMenu !== 'undefined' && activeMenu === 'products' ? 'bg-red-600 text-white shadow-lg shadow-red-500/20' : 'text-zinc-400 hover:bg-zinc-900 hover:text-red-400' %>">
      <svg class="w-5 h-5 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Product Management' %></title>
  <link rel="stylesheet" href="/css/output.css">
</head>
<body class="bg-zinc-900 text-gray-300 font-sans min-h-screen flex flex-col selection:bg-red-600 selection:text-white">

  <!-- Minimal Header -->
  <header class="bg-zinc-950 border-b border-zinc-800 sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="text-xl font-bold tracking-tight text-white hover:text-red-500 transition-colors">
        <span class="text-red-600">PROD</span>SYS
      </a>

      <nav class="flex items-center gap-6">
        <a href="/" class="text-sm font-medium hover:text-red-500 transition-colors">Home</a>
        <% if (typeof user !== 'undefined' && user) { %>
          <div class="flex items-center gap-4 pl-6 border-l border-zinc-700">
            <span class="text-sm text-gray-400">Hi, <%= user.name %></span>
            <% if (user.role === 'admin') { %>
              <a href="/admin" class="text-sm text-red-500 hover:text-red-400 font-semibold transition-colors">Admin Panel</a>
            <% } %>
            <a href="/auth/logout" class="text-sm bg-red-600 hover:bg-red-700 text-white px-4 py-1.5 rounded-md font-medium transition-all">Logout</a>
          </div>
        <% } else { %>
          <div class="flex items-center gap-4 pl-6 border-l border-zinc-700">
            <a href="/auth/login" class="text-sm hover:text-white transition-colors">Login</a>
            <a href="/auth/register" class="text-sm bg-red-600 hover:bg-red-700 text-white px-4 py-1.5 rounded-md font-medium transition-all">Sign Up</a>
          </div>
        <% } %>
      </nav>
    </div>
  </header>

  <!-- Flash Messages Simplified -->
  <div class="max-w-4xl mx-auto px-6 w-full mt-6">
    <% if (typeof success !== 'undefined' && success) { %>
      <% const succArray = Array.isArray(success) ? success : [success]; %>
      <% if (succArray.length > 0) { %>
        <% succArray.forEach(msg => { %>
          <div class="mb-4 bg-zinc-800 border-l-4 border-green-500 text-green-400 p-4 rounded-r-md text-sm"><%= msg %></div>
        <% }) %>
      <% } %>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
      <% const errArray = Array.isArray(error) ? error : [error]; %>
      <% if (errArray.length > 0) { %>
        <% errArray.forEach(msg => { %>
          <div class="mb-4 bg-zinc-800 border-l-4 border-red-500 text-red-400 p-4 rounded-r-md text-sm"><%= msg %></div>
        <% }) %>
      <% } %>
    <% } %>
  </div>
  
  <main class="flex-grow max-w-7xl mx-auto px-6 w-full py-8 text-gray-300">

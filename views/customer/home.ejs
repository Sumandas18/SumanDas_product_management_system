<%- include('../partials/header') %>

<!-- Minimal Dark Hero -->
<div class="mb-10 text-center py-16 bg-zinc-950 border border-zinc-800 rounded-3xl relative overflow-hidden group">
  <div class="absolute inset-0 bg-red-600/5 transition-opacity duration-1000 group-hover:bg-red-600/10"></div>
  <div class="relative z-10 max-w-2xl mx-auto px-6">
    <h1 class="text-4xl md:text-6xl font-black text-white tracking-tight mb-6">ALL <span class="text-red-500">PRODUCTS</span>.</h1>
    <p class="text-zinc-400 text-lg mb-8 max-w-lg mx-auto">Sleek, refined selection of our latest stock.</p>
    
    <!-- Search Bar -->
    <form action="/" method="GET" class="relative max-w-md mx-auto">
      <input type="hidden" name="category" value="<%= selectedCategory %>">
      <input type="text" name="search" value="<%= searchQuery %>" placeholder="Search..." 
             class="w-full bg-zinc-900 border border-zinc-700 text-white pl-6 pr-14 py-3 rounded-full focus:outline-none focus:border-red-500 focus:ring-1 focus:ring-red-500 transition-all placeholder-zinc-500">
      <button type="submit" class="absolute right-2 top-1.5 bottom-1.5 bg-red-600 hover:bg-red-700 text-white rounded-full w-10 flex items-center justify-center transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
      </button>
    </form>
  </div>
</div>

<div class="flex flex-col md:flex-row gap-8 items-start">
  <!-- Minimal Sidebar Filters -->
  <aside class="w-full md:w-56 shrink-0 sticky top-24">
    <div class="bg-zinc-950 border border-zinc-800 rounded-2xl p-5">
      <h2 class="text-xs font-bold text-zinc-500 uppercase tracking-widest mb-4">Categories</h2>
      <ul class="space-y-1">
        <li>
          <a href="/?search=<%= encodeURIComponent(searchQuery) %>" 
             class="block px-3 py-2 text-sm font-medium rounded-md transition-colors <%= !selectedCategory ? 'bg-red-600 text-white' : 'text-zinc-400 hover:bg-zinc-900 hover:text-white' %>">
            All Collections
          </a>
        </li>
        <% categories.forEach(cat => { %>
          <li>
            <a href="/?category=<%= cat._id %>&search=<%= encodeURIComponent(searchQuery) %>" 
               class="block px-3 py-2 text-sm font-medium rounded-md transition-colors <%= selectedCategory === cat._id.toString() ? 'bg-red-600 text-white' : 'text-zinc-400 hover:bg-zinc-900 hover:text-white' %>">
              <%= cat.name %>
            </a>
          </li>
        <% }) %>
      </ul>
    </div>
  </aside>

  <!-- Product Grid -->
  <div class="flex-grow">
    <% if (searchQuery) { %>
      <div class="mb-6 flex items-center gap-4">
        <h2 class="text-sm font-medium text-zinc-400">Results for: <span class="text-white"><%= searchQuery %></span></h2>
        <a href="/" class="text-xs text-red-500 hover:text-red-400 underline underline-offset-4 decoration-red-500/30">Clear Search</a>
      </div>
    <% } %>

    <% if (products && products.length > 0) { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% products.forEach(product => { %>
          <div class="bg-zinc-950 border border-zinc-800 rounded-2xl overflow-hidden hover:border-zinc-700 transition-colors group flex flex-col">
            <a href="/product/<%= product.slug %>" class="relative aspect-[4/3] bg-zinc-900 block overflow-hidden shadow-inner">
              <% if (product.image) { %>
                <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out opacity-90 group-hover:opacity-100" />
              <% } else { %>
                <!-- Force height to maintain card consistency when image is missing -->
                <div class="w-full h-full min-h-[160px] flex items-center justify-center text-zinc-700 font-medium text-xs tracking-widest uppercase">
                  No Image
                </div>
              <% } %>
            </a>
            
            <div class="p-5 flex flex-col flex-grow">
              <span class="text-[10px] font-bold text-red-500 tracking-widest uppercase mb-2">
                <%= product.category ? product.category.name : 'N/A' %>
              </span>
              <a href="/product/<%= product.slug %>">
                <h3 class="font-bold text-lg text-white mb-2 leading-tight group-hover:text-red-400 transition-colors line-clamp-1"><%= product.name %></h3>
              </a>
              <p class="text-zinc-500 text-sm line-clamp-2 mb-6 flex-grow leading-relaxed"><%= product.description %></p>
              
              <a href="/product/<%= product.slug %>" class="w-full bg-zinc-900 hover:bg-red-600 border border-zinc-800 group-hover:border-red-600 text-white text-xs font-bold uppercase tracking-widest text-center py-3 rounded-lg transition-all">
                View Detail
              </a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="bg-zinc-950 border border-zinc-800 rounded-3xl p-16 text-center shadow-2xl">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-zinc-900 text-zinc-600 mb-6">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
        </div>
        <h3 class="text-xl font-black text-white tracking-wide mb-2">NO PRODUCTS FOUND</h3>
        <p class="text-zinc-500 text-sm max-w-sm mx-auto">Try adjusting your filters or search criteria.</p>
        <% if (searchQuery || selectedCategory) { %>
          <a href="/" class="mt-8 inline-block bg-red-600 hover:bg-red-700 text-white text-xs font-bold uppercase tracking-widest py-3 px-8 rounded-full transition-colors">
            Reset Filters
          </a>
        <% } %>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>

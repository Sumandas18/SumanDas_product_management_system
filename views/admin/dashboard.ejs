<%- include('../partials/header') %>

<div class="flex bg-zinc-950 border border-zinc-800 rounded-2xl overflow-hidden shadow-2xl min-h-[75vh]">
  <%- include('../partials/admin-sidebar') %>

  <!-- Main content -->
  <div class="flex-grow p-8 bg-zinc-900">
    <div class="mb-10">
      <p class="text-xs font-bold text-zinc-600 uppercase tracking-widest mb-1">Overview</p>
      <h1 class="text-4xl font-black text-white tracking-tight">DASHBOARD</h1>
    </div>

    <!-- Stat Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">

      <!-- Products Card -->
      <div class="bg-zinc-950 border border-zinc-800 rounded-2xl p-6 flex items-center gap-6 hover:border-red-700/50 transition-colors group">
        <div class="w-14 h-14 rounded-xl bg-red-600/10 border border-red-500/20 flex items-center justify-center flex-shrink-0 group-hover:bg-red-600/20 transition-colors">
          <svg class="w-7 h-7 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
          </svg>
        </div>
        <div>
          <p class="text-xs font-bold text-zinc-600 uppercase tracking-widest mb-1">Total Products</p>
          <h2 class="text-5xl font-black text-white"><%= totalProducts %></h2>
        </div>
      </div>

      <!-- Categories Card -->
      <div class="bg-zinc-950 border border-zinc-800 rounded-2xl p-6 flex items-center gap-6 hover:border-zinc-600 transition-colors group">
        <div class="w-14 h-14 rounded-xl bg-zinc-800 border border-zinc-700 flex items-center justify-center flex-shrink-0 group-hover:bg-zinc-700 transition-colors">
          <svg class="w-7 h-7 text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
          </svg>
        </div>
        <div>
          <p class="text-xs font-bold text-zinc-600 uppercase tracking-widest mb-1">Total Categories</p>
          <h2 class="text-5xl font-black text-white"><%= totalCategories %></h2>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="bg-zinc-950 border border-zinc-800 rounded-2xl p-6">
      <h3 class="text-xs font-bold text-zinc-600 uppercase tracking-widest mb-5">Quick Actions</h3>
      <div class="flex flex-wrap gap-4">
        <a href="/admin/products/add" class="flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white text-xs font-bold uppercase tracking-widest px-5 py-3 rounded-lg transition-all shadow-lg shadow-red-600/20">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
          Add Product
        </a>
        <a href="/admin/categories/add" class="flex items-center gap-2 bg-zinc-800 hover:bg-zinc-700 text-white border border-zinc-700 text-xs font-bold uppercase tracking-widest px-5 py-3 rounded-lg transition-all">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
          Add Category
        </a>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

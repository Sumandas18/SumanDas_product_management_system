<%- include('../../partials/header') %>

<div class="flex bg-zinc-950 border border-zinc-800 rounded-2xl overflow-hidden shadow-2xl min-h-[75vh]">
  <%- include('../../partials/admin-sidebar') %>

  <div class="flex-grow p-8 bg-zinc-900">
    <!-- Header -->
    <div class="flex justify-between items-center mb-8">
      <div>
        <p class="text-xs font-bold text-zinc-600 uppercase tracking-widest mb-1">Products</p>
        <h1 class="text-3xl font-black text-white"><%= title %></h1>
      </div>
      <a href="/admin/products" class="flex items-center gap-2 text-xs font-bold text-zinc-500 hover:text-red-400 uppercase tracking-widest transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Back
      </a>
    </div>

    <!-- Form Card -->
    <div class="max-w-2xl bg-zinc-950 border border-zinc-800 rounded-2xl p-8">
      <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
        <div class="mb-6 border-l-4 border-red-500 bg-red-500/10 p-4 rounded-r-md">
          <% errors.forEach(err => { %>
            <p class="text-red-400 text-sm"><%= err %></p>
          <% }) %>
        </div>
      <% } %>

      <form action="<%= product ? `/admin/products/edit/${product._id}` : '/admin/products/add' %>" method="POST" enctype="multipart/form-data" class="space-y-6">

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Product Name -->
          <div>
            <label for="name" class="block text-xs font-bold text-zinc-500 uppercase tracking-widest mb-2">Product Name</label>
            <input type="text" id="name" name="name"
              value="<%= (typeof oldInput !== 'undefined' && oldInput.name) ? oldInput.name : (product ? product.name : '') %>"
              required autofocus
              class="w-full bg-zinc-900 border border-zinc-800 text-white px-4 py-3 rounded-xl focus:outline-none focus:border-red-500 focus:ring-1 focus:ring-red-500 transition-all placeholder-zinc-700 text-sm">
          </div>

          <!-- Category -->
          <div>
            <label for="category" class="block text-xs font-bold text-zinc-500 uppercase tracking-widest mb-2">Category</label>
            <select id="category" name="category" required
              class="w-full bg-zinc-900 border border-zinc-800 text-white px-4 py-3 rounded-xl focus:outline-none focus:border-red-500 focus:ring-1 focus:ring-red-500 transition-all text-sm">
              <option value="">-- Select Category --</option>
              <% categories.forEach(cat => { %>
                <%
                  let isSelected = false;
                  if (typeof oldInput !== 'undefined' && oldInput.category) {
                    isSelected = oldInput.category === cat._id.toString();
                  } else if (product && product.category) {
                    isSelected = product.category.toString() === cat._id.toString() || (product.category._id && product.category._id.toString() === cat._id.toString());
                  }
                %>
                <option value="<%= cat._id %>" <%= isSelected ? 'selected' : '' %>><%= cat.name %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <!-- Description -->
        <div>
          <label for="description" class="block text-xs font-bold text-zinc-500 uppercase tracking-widest mb-2">Description</label>
          <textarea id="description" name="description" rows="4"
            class="w-full bg-zinc-900 border border-zinc-800 text-white px-4 py-3 rounded-xl focus:outline-none focus:border-red-500 focus:ring-1 focus:ring-red-500 transition-all placeholder-zinc-700 text-sm resize-none"><%= (typeof oldInput !== 'undefined' && oldInput.description) ? oldInput.description : (product ? product.description : '') %></textarea>
        </div>

        <!-- Image Upload -->
        <div>
          <label class="block text-xs font-bold text-zinc-500 uppercase tracking-widest mb-3">Product Image</label>

          <% if (product && product.image) { %>
            <div class="mb-4 flex items-center gap-4 bg-zinc-900 border border-zinc-800 p-4 rounded-xl">
              <img src="<%= product.image %>" alt="Current" class="w-16 h-16 object-cover rounded-lg border border-zinc-700" onerror="this.onerror=null; this.src=''; this.className='hidden'; this.nextElementSibling.classList.remove('hidden');" />
              <!-- Fallback -->
              <div class="hidden w-16 h-16 bg-red-950 border border-red-900 rounded-lg flex items-center justify-center text-red-500 shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              
              <div>
                <p class="text-sm font-semibold text-zinc-300">Current Image</p>
                <p class="text-xs text-zinc-600 mt-1">Upload below to replace it.</p>
                <input type="hidden" name="oldImage" value="<%= product.image %>">
              </div>
            </div>
          <% } %>

          <label for="image" class="flex items-center gap-3 bg-zinc-900 border border-dashed border-zinc-700 hover:border-red-500 text-zinc-500 hover:text-zinc-300 px-5 py-4 rounded-xl cursor-pointer transition-colors group">
            <svg class="w-5 h-5 group-hover:text-red-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
            <span class="text-sm">Click to upload image</span>
            <input type="file" id="image" name="image" accept="image/*" class="hidden">
          </label>
          <p class="text-xs text-zinc-600 mt-2">JPG, PNG, WEBP</p>
        </div>

        <!-- Submit -->
        <div class="flex justify-end pt-4 border-t border-zinc-800">
          <button type="submit" class="flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white text-xs font-bold uppercase tracking-widest px-6 py-3 rounded-lg transition-all shadow-lg shadow-red-600/20">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            <%= product ? 'Update Product' : 'Save Product' %>
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  document.getElementById('image').addEventListener('change', function(e) {
    const fileName = e.target.files[0] ? e.target.files[0].name : 'Click to upload image';
    document.querySelector('#image').previousElementSibling.textContent = fileName;
  });
</script>

<%- include('../../partials/footer') %>

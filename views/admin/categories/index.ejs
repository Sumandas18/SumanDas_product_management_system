<%- include('../../partials/header') %>

<div class="flex bg-zinc-950 border border-zinc-800 rounded-2xl overflow-hidden shadow-2xl min-h-[75vh]">
  <%- include('../../partials/admin-sidebar') %>

  <div class="flex-grow p-8 bg-zinc-900">
    <!-- Header -->
    <div class="flex justify-between items-center mb-8">
      <div>
        <p class="text-xs font-bold text-zinc-600 uppercase tracking-widest mb-1">Admin</p>
        <h1 class="text-3xl font-black text-white">CATEGORIES</h1>
      </div>
      <a href="/admin/categories/add" class="flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white text-xs font-bold uppercase tracking-widest px-5 py-3 rounded-lg transition-all shadow-lg shadow-red-600/20">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
        New Category
      </a>
    </div>

    <!-- Table -->
    <div class="bg-zinc-950 border border-zinc-800 rounded-2xl overflow-hidden">
      <% if (categories && categories.length > 0) { %>
        <table class="w-full text-left">
          <thead>
            <tr class="border-b border-zinc-800">
              <th class="px-6 py-4 text-xs font-bold text-zinc-500 uppercase tracking-widest">Name</th>
              <th class="px-6 py-4 text-xs font-bold text-zinc-500 uppercase tracking-widest">Slug</th>
              <th class="px-6 py-4 text-xs font-bold text-zinc-500 uppercase tracking-widest text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% categories.forEach(category => { %>
              <tr class="border-b border-zinc-900 hover:bg-zinc-900/50 transition-colors">
                <td class="px-6 py-4 font-semibold text-white"><%= category.name %></td>
                <td class="px-6 py-4 font-mono text-xs text-zinc-500"><%= category.slug %></td>
                <td class="px-6 py-4 text-right">
                  <div class="flex items-center justify-end gap-2">
                    <a href="/admin/categories/edit/<%= category._id %>" class="p-2 rounded-lg bg-zinc-800 hover:bg-zinc-700 text-zinc-400 hover:text-white transition-colors">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                    </a>
                    <form action="/admin/categories/delete/<%= category._id %>?_method=DELETE" method="POST" class="inline-block" onsubmit="return confirm('Delete this category?');">
                      <button type="submit" class="p-2 rounded-lg bg-red-600/10 hover:bg-red-600 text-red-500 hover:text-white transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div class="py-20 text-center">
          <p class="text-zinc-600 text-sm mb-4">No categories yet.</p>
          <a href="/admin/categories/add" class="text-red-500 hover:text-red-400 text-sm font-semibold transition-colors">Create your first category →</a>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>
